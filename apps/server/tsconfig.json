{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@api/*": ["src/api/*"],
      "@config/*": ["src/config/*"],
      "@core/*": ["src/core/*"],
      "@database/*": ["src/database/*"],
      "@exchanges/*": ["src/exchanges/*"],
      "@scanner/*": ["src/scanner/*"],
      "@arbitrage/*": ["src/arbitrage/*"],
      "@websocket/*": ["src/websocket/*"],
      "@notifications/*": ["src/notifications/*"],
      "@jobs/*": ["src/jobs/*"],
      "@utils/*": ["src/utils/*"]
    },
    "types": ["node"],
    "noEmit": false
  },
  "include": ["src/**/*"]
}
