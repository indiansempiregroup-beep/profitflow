generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String   @id @default(cuid())
  email                   String   @unique
  passwordHash            String?
  emailVerified           Boolean  @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  resetToken              String?
  resetTokenExpires       DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  exchangeConnections ExchangeConnection[]
  paperTrades         PaperTrade[]
  pushTokens          PushToken[]
  notifications       Notification[]

  @@map("users")
}

model ExchangeConnection {
  id           String   @id @default(cuid())
  userId       String
  exchangeName String
  credentials  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exchangeName])
  @@map("exchange_connections")
}

model MarketSnapshot {
  id            String   @id @default(cuid())
  exchangeName  String
  symbol        String
  bid           Decimal
  ask           Decimal
  lastUpdatedAt DateTime
  createdAt     DateTime @default(now())

  @@map("market_snapshots")
}

model ArbitrageOpportunity {
  id                  String   @id @default(cuid())
  symbol              String
  buyExchange         String
  sellExchange        String
  spread              Decimal
  estimatedProfit     Decimal
  detectedAt          DateTime
  createdAt           DateTime @default(now())
  buyPrice            Decimal
  confidence          Float
  feeAnalysis         Json
  liquidityScore      Json
  marketType          String
  sellPrice           Decimal
  slippageEstimate    Json
  sourceDataTimestamp DateTime
  spreadPercentage    Decimal
  validatedAt         DateTime

  paperTrades PaperTrade[]

  @@map("arbitrage_opportunities")
}

model PaperTrade {
  id              String   @id @default(cuid())
  userId          String
  opportunityId   String?
  symbol          String
  buyExchange     String
  sellExchange    String
  buyPrice        Decimal
  sellPrice       Decimal
  quantity        Decimal  @default(1)
  estimatedProfit Decimal
  status          String   @default("open")
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  realizedProfit  Decimal?
  createdAt       DateTime @default(now())

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity ArbitrageOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@map("paper_trades")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
