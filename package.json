{
  "name": "profitflow",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:server": "DOTENV_CONFIG_PATH=../../.env corepack pnpm --dir apps/server exec tsx watch -r tsconfig-paths/register src/index.ts",
    "dev:mobile": "corepack pnpm --dir apps/mobile exec expo start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run build",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.14.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.1",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  }
}
